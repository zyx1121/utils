#!/usr/bin/env bash
# utils — polyglot dispatcher for self-contained scripts under ../scripts/
# Each script declares its own runtime via shebang (e.g. PEP 723 .py, bash .sh,
# AppleScript .applescript). The dispatcher just looks up by name and execs.
set -euo pipefail
shopt -s nullglob

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
SCRIPTS_DIR="$ROOT/scripts"

list_commands() {
    find "$SCRIPTS_DIR" -maxdepth 1 -type f -perm -u+x 2>/dev/null \
        | sed -E 's|.*/||; s/\.[a-zA-Z]+$//' \
        | sort -u
}

# First-line description for the dispatcher's --help listing.
# .py: first docstring line (PEP 723 metadata block sits above the """).
# .sh / .bash: first comment line after the shebang.
# .applescript: first `-- ...` line.
get_desc() {
    local f="$1"
    case "${f##*.}" in
        py)
            awk '
                /^"""/ {
                    if (seen) exit
                    seen = 1
                    line = $0
                    gsub(/^"""/, "", line)
                    gsub(/"""$/, "", line)
                    if (length(line) > 0) { print line; exit }
                    next
                }
                seen { print; exit }
            ' "$f" 2>/dev/null
            ;;
        sh|bash)
            awk 'NR > 1 && /^#/ && !/^#!/ { sub(/^# */, ""); print; exit }' "$f" 2>/dev/null
            ;;
        applescript|scpt)
            awk '/^--/ { sub(/^-- */, ""); print; exit }' "$f" 2>/dev/null
            ;;
    esac
}

# Two-column "name  description" listing for --help.
# Sort by name (post-extension-strip) so e.g. `image` lands before `image-resize`,
# and dedup if two scripts ever share a name with different extensions.
list_with_descs() {
    find "$SCRIPTS_DIR" -maxdepth 1 -type f -perm -u+x 2>/dev/null \
    | while IFS= read -r f; do
        local n="${f##*/}"
        n="${n%.*}"
        printf '%s\t%s\n' "$n" "$f"
    done \
    | sort -t$'\t' -k1,1 -u \
    | while IFS=$'\t' read -r name f; do
        local desc
        desc=$(get_desc "$f")
        # Strip redundant "<name> — " / "<name> - " prefix common in .sh files.
        desc="${desc#$name — }"
        desc="${desc#$name - }"
        printf "  %-16s %s\n" "$name" "$desc"
    done
}

usage() {
    cat <<EOF
utils — agent-first CLI toolbox

Usage:
  utils <command> [args...]
  utils <command> --help
  utils --help
  utils --list

Available commands:
EOF
    list_with_descs
    cat <<EOF

Each command is a self-contained executable script — runtime is declared via
shebang (PEP 723 Python, bash, AppleScript, ...). First invocation may
download declared deps; later invocations are near-instant.
EOF
}

case "${1:-}" in
    ""|"-h"|"--help")
        usage
        exit 0
        ;;
    "--list")
        list_commands
        exit 0
        ;;
esac

cmd="$1"; shift

# Match scripts/<cmd> (extensionless) or scripts/<cmd>.<ext>. First exec-bit
# match wins. Quoted base + unquoted ".*" lets the glob do the work.
for candidate in "$SCRIPTS_DIR/$cmd" "$SCRIPTS_DIR/$cmd".*; do
    if [ -f "$candidate" ] && [ -x "$candidate" ]; then
        exec "$candidate" "$@"
    fi
done

echo "utils: '$cmd' isn't a thing — try 'utils --help' to see what is" >&2
exit 2
